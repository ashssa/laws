---
import { getCollection, getEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

// 取得所有修正歷程檔案
const allAmendments = await getCollection('amendments');

// 提取出有修法紀錄的獨特法規 ID (target_act)
const uniqueActIds = [...new Set(allAmendments.map(amend => amend.data.target_act))];

// 查詢這些法規的詳細資料以供顯示
const actsWithAmendments = await Promise.all(
  uniqueActIds.map(async (id) => {
    const act = await getEntry('act', id);
    // 計算該法規共有幾次修法紀錄
    const count = allAmendments.filter(a => a.data.target_act === id).length;
    return {
      id,
      title: act?.data.title || id,
      abbr: act?.data.abbr || '',
      count
    };
  })
);
---

<MainLayout title="法規修正歷程總目次">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-10 border-b-2 border-base-300 pb-6">
      <h2 class="text-3xl font-bold mb-3">自治法規修正歷程</h2>
      <p class="text-base-content/70">請選擇您欲查詢修正對照表的法規名稱。</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {actsWithAmendments.map((act) => (
        <a 
          href={`/laws/amendments/${act.id}`} 
          class="card bg-base-100 border border-base-300 hover:border-primary hover:shadow-md transition-all duration-200"
        >
          <div class="card-body p-6">
            <h3 class="card-title text-lg mb-1">{act.title}</h3>
            {act.abbr && <div class="text-sm text-base-content/60 mb-3">{act.abbr}</div>}
            <div class="card-actions justify-end mt-auto">
              <span class="badge badge-primary badge-outline">共 {act.count} 次修正</span>
            </div>
          </div>
        </a>
      ))}
      
      {actsWithAmendments.length === 0 && (
        <div class="col-span-full p-8 text-center bg-base-200 rounded-xl text-base-content/60">
          目前系統中尚無任何法規修正紀錄。
        </div>
      )}
    </div>
  </div>
</MainLayout>