---
import { getCollection, getEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

// 取得所有修正歷程檔案
const allAmendments = await getCollection('amendments');

// 提取出有修法紀錄的獨特法規 ID (target_act)
const uniqueActIds = [...new Set(allAmendments.map(amend => amend.data.target_act))]
  .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }));

// 查詢這些法規的詳細資料以供顯示
const actsWithAmendments = await Promise.all(
  uniqueActIds.map(async (id) => {
    const act = await getEntry('act', id);
    // 計算該法規共有幾次修法紀錄
    const count = allAmendments.filter(a => a.data.target_act === id).length;
    return {
      id,
      title: act?.data.title || id,
      abbr: act?.data.abbr || '',
      count
    };
  })
);
---

<MainLayout title="修法沿革">

    <header class="mb-8 pb-0"><!-- border-b-2 border-base-300  -->
      <div class="text-sm breadcrumbs mb-4 text-base-content/80">
        <ul>
          <li>修法沿革</li>
        </ul>
      </div>

      <h2 class="text-3xl font-bold mb-2">修法沿革</h2>
      <p class="text-base-content/70">※ 本頁面如與學生議會修法沿革不同，以學生議會公告版本為主。</p>
    </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4"><!-- md:grid-cols-2 -->

    {actsWithAmendments.map((act) => (
      <a 
        href={`/laws/amendments/${act.id}`}
        class="flex flex-col sm:flex-row sm:items-center justify-between p-5 bg-base-100 border border-base-200 rounded-2xl hover:border-neutral/50 dark:hover:border-white hover:bg-base-200/40 duration-300 transition"
      >
        <div class="flex-1">
          <h3 class="font-semibold text-lg text-base-content mb-1 truncate">{act.abbr}</h3>
        </div>
        <div class="mt-4 sm:mt-0 sm:ml-6 flex-shrink-0">
          <span class="badge badge-sm md:badge-md badge-secondary badge-dash">修正 {act.count} 次</span>
          <span class="icon-[tabler--chevron-right] ml-2 text-base-content/40 align-middle"></span>
        </div>
      </a>
    ))}

    {actsWithAmendments.length === 0 && (
      <div class="col-span-full p-8 text-center bg-base-200 rounded-xl text-base-content/60">
        目前系統中尚無任何法規修正紀錄。
      </div>
    )}
  </div>
  <div class="grid mt-4"><a class="btn btn-sm btn-outline btn-wide mt-2 mx-auto" href=".">回首頁</a></div>
</MainLayout>

